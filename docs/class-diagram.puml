@startuml
title voivo_movie_maker 現在の全体クラス図

left to right direction
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho
hide empty members

legend left
  |= 記号 |= 意味 |
  | *-- | 所有・ライフサイクルを含む構成 |
  | o-- | 集約・参照 |
  | --> | 実行時の依存 |
  | ..> | 生成・一時利用 |
  | <<Provider>> | Riverpod Provider / Notifier |
  | <<UseCase>> | application/usecases.dart の操作 |
endlegend

package domain {
  class ProjectId
  class AssetId
  class TimelineClipId
  class ClipComponentId

  class Project {
    +ProjectId id
    +String name
    +double width
    +double height
    +int fps
    +int sampleRate
    +ProjectAssetCatalog assets
    +Timeline timeline
  }

  interface IProjectRepository {
    +findAny()
    +getById(id)
    +save(project)
    +delete(id)
  }

  class ProjectAssetCatalog {
    +assets
    +findById(assetId)
    +add(asset)
    +remove(assetId)
  }

  class ProjectAsset {
    +AssetId id
    +String name
    +ProjectAssetKind kind
    +String fileName
  }

  enum ProjectAssetKind {
    image
    video
    audio
  }

  interface IProjectAssetStore {
    +load(asset)
    +save(file)
    +delete(asset)
  }

  class Timeline {
    +tracks
    +addTrack()
    +moveClipToTrack(clipId, trackIndex, startFrame)
    +getActiveClipsAt(frame)
    +getClipById(clipId)
    +getTrackByClipId(clipId)
  }

  class TimelineTrack {
    +clips
    +addClip(clip)
    +removeClip(clipId)
    +canPlaceClip(clip, startFrame, durationFrames)
  }

  class TimelineClip {
    +TimelineClipId id
    +int startFrame
    +int durationFrames
    +int endFrame
    +components
    +addComponent(component)
    +removeComponent(componentId)
    +moveTo(startFrame)
    +trimStartTo(startFrame)
    +trimEndTo(endFrame)
  }

  abstract class ClipComponent {
    +ClipComponentId id
    +String label
    +bool isRemovable
  }

  class TransformComponent {
    +Vector2 position
    +Vector2 scale
    +double rotation
  }

  class ShapeComponent {
    +ShapeType shapeType
    +Size size
    +Color color
  }

  class TextComponent {
    +String text
    +double size
    +Color color
  }

  class ImageComponent {
    +AssetId assetId
    +Size size
  }

  class AudioComponent {
    +AssetId assetId
    +double volume
    +bool muted
  }
  enum ShapeType

  Project *-- ProjectId
  Project *-- ProjectAssetCatalog
  Project *-- Timeline
  ProjectAssetCatalog *-- ProjectAsset
  ProjectAsset *-- AssetId
  ProjectAsset --> ProjectAssetKind
  Timeline *-- TimelineTrack
  TimelineTrack *-- TimelineClip
  TimelineClip *-- TimelineClipId
  TimelineClip *-- ClipComponent
  ClipComponent *-- ClipComponentId
  ClipComponent <|-- TransformComponent
  ClipComponent <|-- ShapeComponent
  ClipComponent <|-- TextComponent
  ClipComponent <|-- ImageComponent
  ClipComponent <|-- AudioComponent
  ImageComponent --> AssetId
  AudioComponent --> AssetId
  ShapeComponent --> ShapeType
}

