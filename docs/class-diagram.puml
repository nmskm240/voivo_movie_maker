  ProjectProvider --> Project
  TimelineNotifier --> ProjectProvider
  TimelineNotifier --> Timeline
  ProjectImageResourcesProvider --> ProjectImageResources

  FetchProjectSummaries --> IProjectRepository
  FetchProjectSummaries ..> ProjectSummary
  CreateProject --> IProjectRepository
  CreateProject ..> Project
