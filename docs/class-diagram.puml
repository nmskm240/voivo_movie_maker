package "application.timeline_editor" {
  class TimelineEditor {
    +execute(project, command)
  }

  interface TimelineEditorCommand {
    +canExecute(timeline)
    +execute(timeline)
  }

  class AddClipCommand
  class AddTrackCommand
  class MoveClipCommand
  class RemoveClipCommand
  class ResizeClipCommand
  class AddClipComponentCommand
  class RemoveClipComponentCommand
  class UpdateClipTransformCommand
  class UpdateShapeComponentCommand
  class UpdateTextClipCommand
  class UpdateImageComponentCommand
  class UpdateAudioComponentCommand

  TimelineEditor --> IProjectRepository : saves after command
  TimelineEditor --> TimelineEditorCommand
  TimelineEditorCommand --> Timeline

  TimelineEditorCommand <|.. AddClipCommand
  TimelineEditorCommand <|.. AddTrackCommand
  TimelineEditorCommand <|.. MoveClipCommand
  TimelineEditorCommand <|.. RemoveClipCommand
  TimelineEditorCommand <|.. ResizeClipCommand
  TimelineEditorCommand <|.. AddClipComponentCommand
  TimelineEditorCommand <|.. RemoveClipComponentCommand
  TimelineEditorCommand <|.. UpdateClipTransformCommand
  TimelineEditorCommand <|.. UpdateShapeComponentCommand
  TimelineEditorCommand <|.. UpdateTextClipCommand
  TimelineEditorCommand <|.. UpdateImageComponentCommand
  TimelineEditorCommand <|.. UpdateAudioComponentCommand

  AddClipCommand --> TimelineClip
  AddClipComponentCommand --> ClipComponent
  RemoveClipComponentCommand --> ClipComponentId
  UpdateClipTransformCommand ..> TransformComponent
  UpdateShapeComponentCommand ..> ShapeComponent
  UpdateTextClipCommand ..> TextComponent
  UpdateImageComponentCommand ..> ImageComponent
}

package "application.rendering" {
  class ProjectImageResources {
    +images
    +revisions
    +load(asset)
    +loadAll(assets)
    +dispose()
  }

  class ProjectFrame {
    +Size projectSize
    +int frameNumber
    +clips
    +imageAssets
  }

  class ProjectFrameBuilder {
    +build(project, frameNumber)
  }

  class ProjectFrameRenderer {
    +paint(canvas, outputSize, frame)
  }

  class ProjectPaintContext {
    +resolvePosition(position)
    +resolveImage(assetId)
  }

  abstract class "ClipPainter<T>" as ClipPainter
  class ShapeClipPainter
  class TextClipPainter
  class ImageClipPainter

  ProjectImageResources --> IProjectAssetStore
  ProjectImageResources --> ProjectAsset
  ProjectImageResources o-- AssetId
  ProjectFrameBuilder --> Project
  ProjectFrameBuilder ..> ProjectFrame
  ProjectFrame o-- TimelineClip
  ProjectFrameRenderer --> ProjectFrame
  ProjectFrameRenderer o-- ClipPainter : painter registry
  ProjectFrameRenderer ..> ProjectPaintContext
  ClipPainter <|-- ShapeClipPainter
  ClipPainter <|-- TextClipPainter
  ClipPainter <|-- ImageClipPainter
  ShapeClipPainter ..> ShapeComponent
  TextClipPainter ..> TextComponent
  ImageClipPainter ..> ImageComponent
}

package "application.export" {
  class ProjectExporter {
